{
  // Visit https://aka.ms/tsconfig to read more about this file.
  // Single config covering src/ and tests/ so the TypeScript language
  // server in VS Code picks up the same compiler options when you open
  // a test file. yarn build still type-checks the lot via tsc -noEmit.
  "include": ["src/**/*", "tests/**/*"],
  "compilerOptions": {
    // Output (only used if tsc actually emits — yarn build runs
    // tsc -noEmit and bundles via esbuild).
    "outDir": "./dist",

    // Environment Settings
    // See also https://aka.ms/tsconfig/module
    "module": "nodenext",
    "target": "esnext",
    "types": ["node"],

    // Other Outputs
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Stricter Typechecking Options
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    // Style Options
    // "noImplicitReturns": true,
    // "noImplicitOverride": true,
    // "noUnusedLocals": true,
    // "noUnusedParameters": true,
    // "noFallthroughCasesInSwitch": true,
    // "noPropertyAccessFromIndexSignature": true,

    // Recommended Options
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  }
}
